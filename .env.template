# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# Twilio Assets base URL (no trailing slash) — from your Twilio Functions/Assets service
TWILIO_ASSET_BASE=https://your-service-name.twil.io

# Public URL where Twilio can reach this app (no trailing slash)
BASE_URL=https://your-tunnel.your-domain.com

# Flask — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Data directory inside the container
DATA_DIR=/app/data

# Google Drive service account — path is inside the container (mounted read-only)
GDRIVE_CREDENTIALS_PATH=/app/secrets/your-credentials-file.json
GDRIVE_FOLDER_ID=your-shared-drive-id

# Allowed inbound callers (E.164, comma-separated) — leave empty to allow all callers
ALLOWED_CALLERS=+15550001111,+15550002222

# Friendly names for callers (E.164:Name pairs, comma-separated)
CALLER_NAMES=+15550001111:Bea,+15550002222:Dustin

# Cloudflare tunnel token — from the Cloudflare dashboard (Networking → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here
