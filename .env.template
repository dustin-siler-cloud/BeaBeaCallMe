# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# Twilio Assets base URL (no trailing slash) — from your Twilio Functions/Assets service
TWILIO_ASSET_BASE=https://your-service-name.twil.io

# Comma-separated list of MP3 filenames hosted on Twilio Assets — Bea's IVR greeting (mentions both menu options)
TWILIO_GREETING_CLIPS=greeting-01.mp3,greeting-02.mp3,greeting-03.mp3

# Comma-separated list of MP3 filenames hosted on Twilio Assets — friend IVR greeting (voicemail option only)
TWILIO_FRIEND_GREETING_CLIPS=friend-greeting-01.mp3

# Public URL where Twilio can reach this app (no trailing slash)
BASE_URL=https://your-tunnel.your-domain.com

# Flask — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Data directory inside the container
DATA_DIR=/app/data

# Google Drive service account — path is inside the container (mounted read-only)
GDRIVE_CREDENTIALS_PATH=/app/secrets/your-credentials-file.json
GDRIVE_FOLDER_ID=your-shared-drive-id

# Google Drive subfolder IDs (within the Shared Drive above) for each message direction
GDRIVE_FOLDER_ID_FROM_BEA=your-from-bea-subfolder-id
GDRIVE_FOLDER_ID_TO_BEA=your-to-bea-subfolder-id

# The single number that routes to Bea's IVR menu (voicemail + group call)
BEA_CALLER_ID=+15550001111

# Comma-separated E.164 numbers that route to the friend IVR menu (voicemail only)
FRIEND_CALLERS=+15550002222,+15550003333

# Comma-separated E.164 numbers Twilio dials when Bea starts a group call
CONFERENCE_PARTICIPANTS=+15550002222,+15550003333

# Friendly names for callers (E.164:Name pairs, comma-separated)
CALLER_NAMES=+15550001111:Bea,+15550002222:Dustin

# Cloudflare tunnel token — from the Cloudflare dashboard (Networking → Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Comma-separated E.164 numbers to text when a new voicemail is saved (optional)
SMS_NOTIFY_NUMBERS=+15550001111,+15550002222

# Email notifications on new voicemail via Resend (optional) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@your-domain.com
EMAIL_NOTIFY_TO=your-address@your-domain.com
